{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MoonChunk",
  "scopeName": "source.moonchunk",
  "fileTypes": ["mncnk"],
  "patterns": [
    { "include": "#shebang" },
    { "include": "#comments" },
    { "include": "#contentBlocks" },
    { "include": "#includeStatements" },
    { "include": "#importStatements" },
    { "include": "#chunkDeclarations" },
    { "include": "#pageDeclarations" },
    { "include": "#functionDeclarations" },
    { "include": "#metaKeys" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#booleans" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functionCalls" },
    { "include": "#identifierPaths" },
    { "include": "#operators" }
  ],
  "repository": {
    "shebang": {
      "patterns": [
        {
          "name": "comment.line.shebang.moonchunk",
          "match": "^#!.*$"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.moonchunk",
          "match": "//.*$"
        }
      ]
    },
    "contentBlocks": {
      "patterns": [
        {
          "name": "meta.block.content.moonchunk",
          "begin": "\\bcontent\\b\\s*\\{",
          "beginCaptures": {
            "0": { "name": "keyword.control.content.moonchunk" }
          },
          "end": "\\}\\s*;",
          "endCaptures": {
            "0": { "name": "punctuation.section.block.end.moonchunk" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#mustacheExpressions" },
            { "include": "#strings" },
            { "include": "#htmlTags" }
          ]
        }
      ]
    },
    "htmlTags": {
      "patterns": [
        {
          "name": "meta.tag.moonchunk",
          "begin": "</?[A-Za-z_][A-Za-z0-9_:-]*",
          "beginCaptures": {
            "0": { "name": "entity.name.tag.moonchunk" }
          },
          "end": "/?>",
          "endCaptures": {
            "0": { "name": "punctuation.definition.tag.end.moonchunk" }
          },
          "patterns": [
            {
              "name": "entity.other.attribute-name.moonchunk",
              "match": "\\b[A-Za-z_][A-Za-z0-9_:-]*(?=\\s*=)"
            },
            {
              "name": "keyword.operator.assignment.moonchunk",
              "match": "="
            },
            { "include": "#strings" },
            { "include": "#mustacheExpressions" }
          ]
        }
      ]
    },
    "mustacheExpressions": {
      "patterns": [
        {
          "name": "meta.embedded.expression.moonchunk",
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.moonchunk" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.moonchunk" }
          },
          "patterns": [
            { "include": "#comments" },
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#metaKeys" },
            { "include": "#keywords" },
            { "include": "#types" },
            { "include": "#booleans" },
            { "include": "#functionCalls" },
            { "include": "#identifierPaths" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "includeStatements": {
      "patterns": [
        {
          "name": "meta.include.statement.moonchunk",
          "begin": "@include\\b",
          "beginCaptures": {
            "0": { "name": "keyword.control.include.moonchunk" }
          },
          "end": "(?=;|$)",
          "patterns": [
            { "include": "#identifierPaths" },
            {
              "name": "variable.other.readwrite.moonchunk",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "importStatements": {
      "patterns": [
        {
          "name": "meta.import.statement.moonchunk",
          "begin": "\\bimport\\b",
          "beginCaptures": {
            "0": { "name": "keyword.control.import.moonchunk" }
          },
          "end": "(?=;|$)",
          "patterns": [
            {
              "name": "keyword.control.import.moonchunk",
              "match": "\\b(from|as)\\b"
            },
            { "include": "#strings" },
            { "include": "#identifierPaths" },
            {
              "name": "keyword.operator.wildcard.moonchunk",
              "match": "\\*"
            },
            {
              "name": "punctuation.separator.moonchunk",
              "match": "[{},]"
            }
          ]
        }
      ]
    },
    "chunkDeclarations": {
      "patterns": [
        {
          "name": "meta.declaration.chunk.moonchunk",
          "match": "\\b(export\\s+)?(chunk)\\b\\s+(\"(?:\\\\.|[^\"\\\\])*\")",
          "captures": {
            "1": { "name": "keyword.control.export.moonchunk" },
            "2": { "name": "storage.type.declaration.moonchunk" },
            "3": { "name": "entity.name.type.chunk.moonchunk" }
          }
        }
      ]
    },
    "pageDeclarations": {
      "patterns": [
        {
          "name": "meta.declaration.page.moonchunk",
          "match": "\\b(page)\\b\\s+(\"(?:\\\\.|[^\"\\\\])*\")",
          "captures": {
            "1": { "name": "keyword.control.page.moonchunk" },
            "2": { "name": "string.quoted.double.path.moonchunk" }
          }
        }
      ]
    },
    "functionDeclarations": {
      "patterns": [
        {
          "name": "meta.function.declaration.moonchunk",
          "match": "\\b(function)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.moonchunk" },
            "2": { "name": "entity.name.function.moonchunk" }
          }
        },
        {
          "name": "meta.function.arrow.moonchunk",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b\\s*=\\s*(?:\\([^\\)]*\\)|[A-Za-z_][A-Za-z0-9_]*)\\s*(?::\\s*[A-Za-z_][A-Za-z0-9_]*)?\\s*=>",
          "captures": {
            "1": { "name": "entity.name.function.moonchunk" }
          }
        }
      ]
    },
    "metaKeys": {
      "patterns": [
        {
          "name": "variable.other.meta-key.moonchunk",
          "match": "\\b(?:lang|dir|htmlClass|charset|viewport|title|metaDescription|metaKeywords|metaAuthor|metaRobots|themeColor|canonicalUrl|faviconHref|appleTouchIconHref|manifestHref|ogType|ogTitle|ogDescription|ogImage|ogUrl|ogSiteName|ogLocale|twitterCard|twitterSite|twitterCreator|twitterTitle|twitterDescription|twitterImage|preloadLinks|preconnectLinks|styles|headScripts|headExtra|bodyClass|pageId|topBar|header|footer|modals|scripts|bodyEndExtra)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.moonchunk",
          "match": "\\b(?:chunk|export|moon|output|env|global|page|content|const|let|function|return|for|while|break|continue|if|else|import|from|in|as|and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.moonchunk",
          "match": "\\b(?:int|float|double|bool|string|number|object|array|null|undefined|unknown|any|void)\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.moonchunk",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.moonchunk",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.moonchunk",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.moonchunk",
          "match": "\\b\\d+(?:\\.\\d+)?[fFdD]?\\b"
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "name": "support.function.call.moonchunk",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "support.function.call.moonchunk" }
          }
        }
      ]
    },
    "identifierPaths": {
      "patterns": [
        {
          "name": "entity.name.namespace.path.moonchunk",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.moonchunk",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.moonchunk",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.moonchunk",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.moonchunk",
          "match": "\\+\\+|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.accessor.moonchunk",
          "match": "\\."
        },
        {
          "name": "punctuation.separator.moonchunk",
          "match": "[,;:]"
        },
        {
          "name": "punctuation.section.group.begin.moonchunk",
          "match": "[\\(\\{\\[]"
        },
        {
          "name": "punctuation.section.group.end.moonchunk",
          "match": "[\\)\\}\\]]"
        },
        {
          "name": "keyword.operator.ternary.moonchunk",
          "match": "\\?"
        }
      ]
    }
  }
}
