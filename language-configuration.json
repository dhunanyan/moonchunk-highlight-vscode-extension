{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] },
    { "open": "`", "close": "`", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*(\\{[^}]*|\\([^)]*|\\[[^\\]]*)$",
    "decreaseIndentPattern": "^\\s*[\\}\\)\\]].*$"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^`~!@#$%^&*()=+\\[{\\]}\\\\|;:'\",.<>/?\\s]+)",
  "folding": {
    "markers": {
      "start": "^\\s*(//\\s*)?#region\\b",
      "end": "^\\s*(//\\s*)?#endregion\\b"
    }
  }
}
